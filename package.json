{
    "name": "grav",
    "displayName": "Grav — Autopilot for Antigravity",
    "description": "AI Autopilot for Windsurf / Antigravity IDE (v1.19 to 1.24+). Auto-click approvals, auto-scroll chat, and guard terminal commands. Boost your workflow with adaptive learning and CDP-first reliability.",
    "version": "4.0.11",
    "icon": "icons/icon.png",
    "publisher": "anlvdt",
    "author": {
        "name": "An Le",
        "email": "anlvdt@gmail.com",
        "url": "https://github.com/anlvdt"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/anlvdt/grav"
    },
    "homepage": "https://github.com/anlvdt/grav#readme",
    "bugs": {
        "url": "https://github.com/anlvdt/grav/issues"
    },
    "keywords": [
        "antigravity",
        "windsurf",
        "copilot",
        "ai-assistant",
        "automation"
    ],
    "license": "MIT",
    "engines": {
        "vscode": "^1.60.0"
    },
    "extensionKind": [
        "ui"
    ],
    "categories": [
        "Other",
        "Machine Learning"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "grav.dashboard",
                "title": "Grav: Dashboard"
            },
            {
                "command": "grav.diagnostics",
                "title": "Grav: Diagnostics"
            },
            {
                "command": "grav.manageTerminal",
                "title": "Grav: Manage Terminal Commands (Whitelist/Blacklist)"
            },
            {
                "command": "grav.learnStats",
                "title": "Grav: View Learning Stats"
            },
            {
                "command": "grav.refreshObserver",
                "title": "Grav: Refresh Observer (Force re-inject)"
            },
            {
                "command": "grav.forceReconnect",
                "title": "Grav: Force Reconnect CDP"
            },
            {
                "command": "grav.pauseAccept",
                "title": "Grav: Pause Auto-Accept"
            },
            {
                "command": "grav.toggleScroll",
                "title": "Grav: Toggle Auto-Scroll"
            },
            {
                "command": "grav.resumeAccept",
                "title": "Grav: Resume Auto-Accept"
            },
            {
                "command": "grav.stopAllTerminals",
                "title": "Grav: Stop All Terminals"
            },
            {
                "command": "grav.acceptAll",
                "title": "Grav: Force Accept All"
            },
            {
                "command": "grav.toggleDryRun",
                "title": "Grav: Toggle Dry Run (scan without clicking)"
            },
            {
                "command": "grav.initProjectConfig",
                "title": "Grav: Init Project Config (.vscode/grav.json)"
            },
            {
                "command": "grav.purgeLearning",
                "title": "Grav: Purge Bad Learning Data"
            },
            {
                "command": "grav.resetLearningData",
                "title": "Grav: Factory Reset Learning Data"
            },
            {
                "command": "grav.toggleSkipBrowserAgent",
                "title": "Grav: Toggle Skip Browser Agent"
            }
        ],
        "keybindings": [
            {
                "command": "grav.dashboard",
                "key": "ctrl+shift+d",
                "mac": "cmd+shift+d"
            },
            {
                "command": "grav.pauseAccept",
                "key": "ctrl+shift+p",
                "mac": "cmd+shift+p",
                "when": "false"
            },
            {
                "command": "grav.stopAllTerminals",
                "key": "ctrl+shift+q",
                "mac": "cmd+shift+q"
            }
        ],
        "configuration": {
            "title": "Grav",
            "properties": {
                "grav.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable Grav entirely."
                },
                "grav.autoScroll": {
                    "type": "boolean",
                    "default": true,
                    "description": "Keep chat panel scrolled to the bottom while the AI is responding. Pauses automatically when the user scrolls up."
                },
                "grav.presetMode": {
                    "type": "string",
                    "enum": [
                        "1.19.6",
                        "1.23.2",
                        "1.24+",
                        "custom"
                    ],
                    "default": "1.24+",
                    "description": "Select preset button patterns based on Antigravity/Windsurf version. 1.19.6 = v1.19–v1.22; 1.23.2 = v1.23; 1.24+ = latest (Run Task, Continue); custom = use grav.approvePatterns."
                },
                "grav.approvePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Accept",
                        "Accept All",
                        "Retry",
                        "Run Task",
                        "Run",
                        "Approve",
                        "Allow in Workspace"
                    ],
                    "description": "List of button labels to auto-click in the agent panel. Case-sensitive. Add custom labels for per-project buttons."
                },
                "grav.scrollPauseMs": {
                    "type": "number",
                    "default": 15000,
                    "description": "How long to pause auto-scroll after the user manually scrolls up (milliseconds)."
                },
                "grav.scrollIntervalMs": {
                    "type": "number",
                    "default": 500,
                    "description": "Interval between scroll ticks (milliseconds)."
                },
                "grav.approveIntervalMs": {
                    "type": "number",
                    "default": 1000,
                    "description": "Interval between button scan cycles (milliseconds). Minimum enforced: 3000ms."
                },
                "grav.language": {
                    "type": "string",
                    "enum": [
                        "vi",
                        "en",
                        "zh"
                    ],
                    "default": "vi",
                    "description": "UI language for Grav dashboard (vi = Vietnamese, en = English, zh = Chinese)."
                },
                "grav.terminalWhitelist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Additional terminal commands to always allow. Supplements the built-in safe command list."
                },
                "grav.terminalBlacklist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Terminal commands to always block. Supports plain substrings and /regex/ patterns."
                },
                "grav.learnEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable adaptive learning. Grav observes terminal command approve/reject behavior and suggests whitelist/blacklist entries."
                },
                "grav.learnThreshold": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 50,
                    "description": "Number of approvals required before Grav suggests promoting a command to the whitelist."
                },
                "grav.cdpEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Chrome DevTools Protocol engine. Required to reach buttons inside OOPIF webviews. Auto-configured on first install."
                },
                "grav.cdpPort": {
                    "type": "number",
                    "default": 9333,
                    "description": "CDP remote debugging port. Default 9333 avoids conflict with Antigravity Browser Control (9222)."
                },
                "grav.skipTerminalAccept": {
                    "type": "boolean",
                    "default": true,
                    "description": "Skip blind terminal accept via VS Code API. Let the CDP Safety Guard handle Run button clicks instead."
                },
                "grav.dryRun": {
                    "type": "boolean",
                    "default": false,
                    "description": "Dry Run mode: scan and match buttons but do not click. Use for debugging. Activity log shows what would be clicked."
                },
                "grav.skipBrowserAgent": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip auto-click when Browser Agent is active. Pauses Grav when Antigravity triggers a browser/computer-use agent."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "echo ok",
        "test": "node test/run-all.js",
        "build": "npm install && npx -y @vscode/vsce package"
    },
    "dependencies": {
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^6.0.1",
        "vite": "^8.0.10"
    }
}
